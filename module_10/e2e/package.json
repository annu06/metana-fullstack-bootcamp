{
  "name": "blog-e2e-tests",
  "version": "1.0.0",
  "description": "End-to-end tests for blog application using Selenium WebDriver",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:headless": "HEADLESS=true jest",
    "test:chrome": "BROWSER=chrome jest",
    "test:firefox": "BROWSER=firefox jest"
  },
  "dependencies": {
    "selenium-webdriver": "^4.15.0",
    "chromedriver": "^119.0.0",
    "geckodriver": "^4.2.1"
  },
  "devDependencies": {
    "jest": "^29.6.2",
    "@types/selenium-webdriver": "^4.1.20"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFilesAfterEnv": ["<rootDir>/setup.js"],
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/*.e2e.test.js"
    ],
    "testTimeout": 30000,
    "verbose": true
  }
}