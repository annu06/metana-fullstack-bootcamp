{
  "name": "blog-testing-scripts",
  "version": "1.0.0",
  "description": "Testing and coverage scripts for the blog application",
  "main": "test-coverage.js",
  "scripts": {
    "coverage": "node test-coverage.js",
    "coverage:backend": "node test-coverage.js --frontend-only",
    "coverage:frontend": "node test-coverage.js --backend-only",
    "coverage:full": "node test-coverage.js --e2e",
    "test:all": "npm run test:backend && npm run test:frontend",
    "test:backend": "cd ../backend && npm test",
    "test:frontend": "cd ../frontend && npm test -- --watchAll=false",
    "test:e2e": "cd ../e2e && npm test"
  },
  "keywords": [
    "testing",
    "coverage",
    "jest",
    "react",
    "node",
    "selenium"
  ],
  "author": "Blog App Team",
  "license": "MIT",
  "dependencies": {
    "fs-extra": "^11.1.1"
  },
  "engines": {
    "node": ">=14.0.0"
  }
}