{
  "name": "module-8-fullstack",
  "version": "1.0.0",
  "description": "React frontend with Node.js backend integration",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm start",
